# AI Code Reviewer Configuration
# Copy this file to .env and update with your settings

# Application Settings
DEBUG=False
APP_ENV=development

# Database Settings
DATABASE_PATH=./code_reviewer.db

# Server Settings
SERVER_HOST=0.0.0.0
SERVER_PORT=8501

# File Upload Settings
MAX_FILE_SIZE=1048576
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports

# Analysis Settings
MAX_CODE_LENGTH=1000000
CHUNK_SIZE=5000
ANALYSIS_TIMEOUT=30

# Security Settings
SECRET_KEY=change-this-in-production-use-a-strong-random-key
PASSWORD_MIN_LENGTH=6

# GitHub API Settings (optional - for GitHub integration)
GITHUB_TOKEN=
GITHUB_API_TIMEOUT=10

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Logging Settings
LOG_LEVEL=INFO
LOG_FILE=./code_reviewer.log